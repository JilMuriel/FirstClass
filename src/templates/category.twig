{# This file demonstrates using most of the index.twig template and modifying
just a small part. See `search.twig` for an example of another approach #}

{% extends "index.twig" %}

{% block content %}

	{# Showing posts archive #}
	{% if posts|length > 0 %}

		{% if post_cat[0].cat_name == title %}
			<section class="firstclass-category-content-left w-full mx-auto {% if fields.pagepicker.light_verstion %}light-version{% endif %}">
				<div class="container mx-auto py-[80px] grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{% for post in posts %}
					{% set category_id = fields.blog.term_id %}
					{% set link = fn('get_permalink', post.ID) %}
					{% set thumbnail_url = fn('get_the_post_thumbnail_url', post.ID ) %}
						<article class="rounded-xl full flex flex-col text-center lg:text-left  bg-[#F3F9FF]">
	
						
						<div class="p-6">
							<img src="{{ thumbnail_url }}" class="w-full h-[250px] rounded-xl object-cover">
							<div class="flex flex-row space-x-2 justify-center lg:justify-start items-center mt-4 mb-4">
								<img src="{{ site.theme.link }}/images/icons/calendar.svg">
								<span class="text-[12px] text-dark">{{ post.published_at|date("j F Y") }}</span>
							</div>
							<h3 class='font-tagline text-md lg:text-lg mb-4 mt-4 text-dark'>{{ post.post_title }}</h3>
							{% if post.post_excerpt %}	
							<p class="font-body text-base">{{ post.post_excerpt }}</p>
							{% endif %}
							<div class="flex justify-center lg:justify-start">
								<a class='btn btn-primary font-tagline  !w-fit ' href="{{ link }}">READ MORE</a>
							</div>		
						</div>	
					</article>
					{% endfor %}
				</div>
			</section>


		{% endif %}
	{% elseif posts|length == 0 and categories == 0 %}
		<div class="section px-10 py-[80px] mb-10">
			<h2 class="text-4xl font-light mb-4">Unfortunately no match was found.... try again!</h2>
		</div>
	{% endif %}


{% endblock %}
