{#
  Title: Icon Box Grid
  Description: A grid section with icon boxes.
  Category: formatting
  Icon: grid-view
  Keywords: about
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="mammothmoving-iconbox section-spacing bg-lightgray {{ block.className }}">
<div class="container mx-auto">
	<div class="flex flex-row justify-center mb-8"><span class="mm-icon-red"></span></div>
	{% if fields.title %}
	<h2 class="font-tagline  text-dark text-[32px] leading-[35px] lg:text-xl text-center mb-4">{{ fields.title}}</h2>
	{% endif %}
	{% if fields.upper_title %}
	<h3 class="mb-8 lg:mb-20 text-center text-base text-dark">{{ fields.upper_title }}</h3>
	{% endif %}
	{% if fields.box %}
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
		{% for item in fields.box %}
		{% if item.button.url %}
		<a href="{{ item.button.url }}" class="icon-link">
			<article class="h-full min-h-[220px] lg:h-[220px]  rounded-lg" style=" background:  url('{{ item.icon.url }}');background-repeat: no-repeat, no-repeat;background-size: cover, cover">
				<div class="w-full h-full flex flex-col items-center justify-end bg-[#332D2D]/60 px-4 py-8 rounded-lg">
					<img src="{{ site.theme.link }}/images/icons/mammoth-icon.svg" class="injectable mb-4">
					<h3 class="text-white font-tagline text-lg text-center">{{item.title}}</h3>	
				</div>		
			
			</article>
		</a>
		{% else %}	
			<article class="min-h-[220px] lg:h-[220px]  rounded-lg" style=" background:  url('{{ item.icon.url }}');background-repeat: no-repeat, no-repeat;background-size: cover, cover">
				<div class="w-full h-full flex flex-col items-center justify-end bg-[#332D2D]/60 px-4 py-8 rounded-lg">
					<img src="{{ site.theme.link }}/images/icons/mammoth-icon.svg" class="injectable mb-4">
					<h3 class="text-white font-tagline text-lg text-center">{{item.title}}</h3>	
				</div>		
			</article>
		{% endif %}
		{% endfor %}
	</div>
	{% endif %}
	{% if fields.button_link %}
	<div class="container mt-12 text-center mx-auto">
		<a href="{{ fields.button_link.url }}"
			class="btn btn-primary">
			<span>
				{{ fields.button_link.title }}
			</span>
		</a>
	</div>
	{% endif %}
	</div>
</section>
