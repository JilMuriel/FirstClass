{#
  Title: Map
  Description: Map block
  Category: formatting
  Icon: location
  Keywords: map
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="mammothmoving-imagetext right section-spacing  bg-[#F8F8F8] ">
	<article class="container flex flex-col items-center justify-between mx-auto lg:flex-row gap-[30px]">
		<div class="relative w-full h-[516px] mt-8 rounded-[8px] shadow lg:mt-0 lg:w-5/12 image-wrap shadow-lg overflow-hidden">
			{{ fields.map_embed }}
		</div>
		<div class="w-full lg:w-6/12">
			<h2 class="leading-[55px] text-[#333333] font-bold uppercase md:mb-[40px] text-[30px] md:text-[40px] text-center md:text-left">Areas we serve</h2>
			<!-- Features -->
			<div class="flex gap-[32px] mt-4 mb-[40px] text-[#1A1A1A]">
				<div class="max-w-[520px] flex flex-col md:flex-row flex-wrap gap-[16px]">
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						Altamonte Springs
					</span>
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						Boynton Beach
					</span>
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						North Sarasota
					</span>
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						New Port Richey
					</span>
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						Altamonte Springs
					</span>
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						Boynton Beach
					</span>
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						North Sarasota
					</span>
					<span class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="/wp-content/uploads/2026/03/house-building-1-4.png" alt="">
						New Port Richey
					</span>
				</div>

			</div>
			<button class="hidden md:block">
				<a href="{{ fields.button.url}}" class="mb-4 font-bold normal-case btn btn-primary">View All Areas
				</a>
			</button>
		</div>
	</article>
</section>


