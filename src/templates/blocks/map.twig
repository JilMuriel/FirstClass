{#
  Title: Map
  Description: Map block
  Category: formatting
  Icon: location
  Keywords: map
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}
<section class="firstclass-imagetext right section-spacing  bg-[#F8F8F8] ">
	<article class="container flex flex-col items-center justify-between mx-auto lg:flex-row gap-[30px]">
		<figure class="relative w-full mt-8 rounded-[8px]  lg:mt-0 lg:w-6/12  overflow-hidden">
			<img src="{{ fields.map_image }}" alt="Map" class="w-full h-full">
		</figure>
		<div class="w-full lg:w-6/12">
			<h2 class="leading-[55px] text-[#333333] font-bold uppercase md:mb-[40px] text-[30px] md:text-[40px] text-center md:text-left">{{ fields.title }}</h2>
			<!-- Features -->
			<div class="flex gap-[32px] mt-4 mb-[40px] text-[#1A1A1A]">
				<div class="max-w-[520px] flex flex-col md:flex-row flex-wrap gap-[16px]">

				{% for box in fields.box.area_list %}
					<a href="{{ box.link.url }}" class="flex text-[18px] font-bold items-center gap-2 px-[16px] py-[14px] rounded-[10px] border border-[#E4E4E4]">
						<img src="{{ fields.box.icon.url }}" alt="">
						{{ box.link.title }}
					</a>
				{% endfor %}

			</div>
		</div>
		<a href="{{ fields.button.url}}" class="mb-4 font-bold normal-case btn btn-primary hidden md:block">{{ fields.button.title}}
				</a>
	</article>
</section>