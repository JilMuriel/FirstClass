{#
  Title: Icon List
  Description: Icon List Section.
  Category: formatting
  Icon: editor-ul
  Keywords: about
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}


<section class="bg-[#D9EAF4] px-[20px] py-[60px] md:py-[90px] lg:py-[120px]">
	<div class="container mx-auto text-center md:w-[796px] mb-[60px]">
		<h2 class="leading-[55px] text-[#4E4D4D] font-bold uppercase md:mb-[30px] text-[30px] md:text-[40px]">{{ fields.title }}</h2>
		<p class="text-[#402e2e] text-[16px] font-regular">
			{{ fields.upper_title }}
		</p>
	</div>
	<div class="container px-4 mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-[60px]">
   		{% for box in fields.icon_list %}
			<div class="text-center text-[#402e2e]">
				<div class="mb-8 h-[80px] w-[80px] bg-white rounded-full flex items-center justify-center mx-auto">
					<img src="{{ box.icon.url }}" class="h-[42px] w-auto"/>
				</div>
				<p class="font-bold text-[22px] mb-6">{{ box.title }}</p>
				<p class="leading-[28px] text-[16px]">{{ box.description }}</p>
			</div>
		{% endfor %}
	</div>
	<button class="hidden mx-auto md:block">
		<a href="{{ fields.button.url}}" class="mb-4 font-bold normal-case btn btn-primary">{{ fields.button.title}}
		</a>
	</button>
</section>


</section>