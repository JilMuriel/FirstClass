{#
  Title: Blog
  Description: Blog block
  postegory: Firebase-blocks
  Icon: welcome-write-blog
  Keywords: services
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="bg-[#F8F8F8] px-[20px] py-[60px] md:py-[90px] lg:py-[120px] {{ block.className }}">
{% for fpost in fposts %}
	{{fpost.post_title}}<br>
{% endfor %}
<div class="container flex flex-col mx-auto text-center">
	{% if fields.upper_title %}
		<h2 class="leading-[55px] text-[#333] font-bold uppercase md:mb-[20px] text-[30px] md:text-[40px]">{{ fields.upper_title}}</h2>
	{% endif %}
	{% if fields.title %}
		<h2 class="leading-[55px] text-[#4E4D4D] font-bold uppercase mb-[60px] text-[30px] md:text-[40px]">Moving Tips & Advice</h2>
		{# <h2 class="font-header text-dark text-[35px] leading-[35px] lg:text-xl mb-8">{{ fields.title}}</h2> #}
	{% endif %}
	{% if fields.subtitle %}
		<h4 class="mb-4 text-lg font-light">{{ fields.subtitle}}</h4>
	{% endif %}
</div>

<section class="container mx-auto">

  <div class="px-[20px]">

    <!-- Swiper -->
    <div class="overflow-hidden blog-swiper02 swiper">

      <div class="swiper-wrapper">

        <!-- Article -->
        <article class="swiper-slide border border-[#4E4D4D29] rounded-[8px] p-[16px] h-full">
          
          <div class="flex flex-col h-full">

            <img src="/wp-content/uploads/2026/03/house-building-1-5.png"
                 class="h-[210px] w-full object-cover rounded-[6px] mb-[30px]">

            <div class="flex flex-col flex-grow px-[20px] pb-[20px]">

              <div class="flex items-center uppercase gap-[8px] mb-[25px]">
                <img src="{{ site.theme.link }}/images/icons/calendar.svg">
                <span class="text-[12px]">01 November 2025</span>
              </div>

              <h3 class="text-[18px] font-bold leading-[24px] mb-[25px]">
                Lorem ipsum dolor sit amet sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
              </h3>

              <p class="mb-[30px] flex-grow">
                Lorem ipsum dolor sit amet adipiscing elit sed doe eiusmod tempor.
              </p>

              <a href="{{ link }}"
                 class="flex items-center justify-center w-[131px] h-[48px] rounded-[5px] bg-blue text-white text-[16px] font-bold text-center">
                Read More
              </a>

            </div>

          </div>

        </article>

        <!-- Duplicate slides -->
