{#
  Title: Image Progress Steps
  Description: Image Progress Steps Section.
  Category: formatting
  Icon: backup
  Keywords: about
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}
<section class="firstclass-whychooseus section-spacing bg-white {{ block.className }}">
	{% if fields.upper_title and fields.title %}
	<div class="container mx-auto flex flex-col text-center pb-1 mb-10">
		<h2 class="font-header text-secondary text-xl g:text-5xl mb-8">{{ fields.title}}</h2>
		<h3 class="mb-2">{{ fields.upper_title }}</h3>
	</div>
	{% else %}
	{% if fields.upper_title %}
	<h3 class="font-header tracking-wider text-base uppercase mb-2">{{ fields.upper_title }}</h3>
	{% endif %}
	{% if fields.title %}
	<h2 class="font-header text-2xl lg:text-5xl mb-8">{{ fields.title}}</h2>
	{% endif %}
	{% endif %}
	{% if fields.box %}
		<div class="grid md:grid-cols-3 xl:grid-cols-5 lg:space-x-2">
			{% for item in fields.box %}
			<article class="text-center bg-white p-6">
				<div class="mx-auto"
					data-aos="fade-up" data-aos-offset="150" data-aos-delay="{{loop.index}}50"
					data-aos-duration="2*{{loop.index}}50" data-aos-once="true">
					{% if item.icon.url %}
					<img src="{{ item.icon.url }}" title="{{ item.icon.title }}" alt="{{ item.icon.alt }}"
						class="injectable mx-auto mb-4">
					{% endif %}
				</div>
				{% if item.title %}
				<h3 class="title text-xl  lg:text-2xl mb-4 font-button">{{item.title}}
				</h3>
				{% endif %}
				{% if item.description %}
				<div class="description text-base lg:text-sm">{{item.description}}</div>
				{% endif %}
			</article>
			{% endfor %}

		</div>
	{% endif %}
</section>
