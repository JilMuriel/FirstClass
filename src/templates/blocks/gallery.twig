{#
  Title: Gallery
  Description: Gallery section
  Category: firstclass-blocks
  Icon: editor-ul
  Keywords: about
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="norcal-gallery section-spacing {{ block.className }}">
	<div class="container mx-auto">
		<div class="flex items-center">
			<h2 class="font-header text-secondary text-xl g:text-5xl mb-8 mx-auto">{{fields.heading}}</h2>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2  lg:grid-cols-3 gap-4 lg:gap-10">
			{% for item in fields.images_gallery %}
        
          {% if item.link.url %}
            <div class="w-full">
                <a href="{{ item.link.url }}"  target="{{ item.link.target }}">
                <img src="{{item.image.url}}" alt="{{item.image.alt}}">
                 <h3 class="font-header text-dark  text-[20px] lg:text-[30px]  mb-4 mt-4">{{  item.link.title }}</h3>
                </a>
            </div>

          {% else %}
               <img src="{{item.image.url}}"  alt="{{item.image.alt}}">
          {% endif %}

        {% endfor %}
		</div>
	</div>

</section>
