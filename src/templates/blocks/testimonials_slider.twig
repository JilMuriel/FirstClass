{#
  Title: Testimonials Slider
  Description: Testimonials block
  Category: firstclass-blocks
  Icon: list-view
  Keywords: testimonials
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

{% if fields.review_version == 'ver1' %}
<section class="firstclass-testimonials v1 mb-16 lg:mb-24 {{ block.className }}">
	<div class="flex flex-col lg:flex-row">
		<div class="w-full pt-16 pb-32 md:px-24 flex flex-col">
			{% if fields.title %}
			<h2 class="font-tagline text-[32px] leading-[32px] lg:text-xl text-left  text-dark mb-8 capitalize">{{ fields.title}}</h2>
			{% endif %}
			{% if fields.upper_title %}
				<p class="mb-4 text-center w-full lg:w-7/12 mx-auto text-dark">{{ fields.upper_title }}</p>
			{% endif %}		
			<div class="testimonials w-[100%]">
				{{fn('do_shortcode', fields.testimonials|striptags)}}
			</div>
		</div>
	</div>
	{% if fields.button_link %}
	<div class="mt-32 xl:mt-12 text-center">
		<a href="{{ fields.button_link.url }}" class="btn btn-secondary">
			<span>
				{{ fields.button_link.title }}
			</span>
		</a>
	</div>
	{% endif %}
</section>
{% endif %}
