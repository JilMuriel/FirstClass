{#
  Title: CTA
  Description: Call To Action block
  Category: mammothmoving-blocks
  Icon: table-row-before
  Keywords: offer
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="mammothmoving-cta  section-spacing  {{ block.className }}">
    <div
		class="w-[95%] xl:w-[55%]  mx-auto flex flex-col items-center justify-center bg-primary/90 rounded-md p-6 xl:p-12">
		<div class="flex flex-row justify-center"><span class="mm-icon-wh"></span></div>
		{% if fields.cta_title %}
		<h2 class="font-tagline  text-white text-[32px] leading-[35px] lg:text-xl  text-center">{{ fields.cta_title}}</h2>
		{% endif %}
    		{% if fields.description %}
          <p class="text-white text-center mt-6">{{ fields.description}}</p>
    		{% endif %}
		{% for button in fields.cta_button %}
		<a href="{{ button.btn_link.url}}" 
			class="btn btn-ghost mt-8 !w-fit">
			<span class=''>{{button.btn_link.title}}</span>
		</a>
		{% endfor %}
	</div>
</section>
