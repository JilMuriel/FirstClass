			<button class="swiper-button-prev-desktop w-[60px] h-[60px] bg-[#333] hover:bg-[#EE4035] rounded-full after:flex flex items-center justify-center">
				<img src="/wp-content/uploads/2026/03/Vector-3.png" alt="">
			</button>
		</div>

		<div class="w-full max-w-[1244px] block relative border"></div>
		<div class="relative top-[28px!important] z-20 md:block">
			<button class="swiper-button-next-desktop w-[60px] h-[60px] bg-[#333] hover:bg-[#EE4035] rounded-full after:flex flex items-center justify-center">
				<img src="/wp-content/uploads/2026/03/Vector-4.png" alt="">
			</button>
		</div>
	</div>
	
