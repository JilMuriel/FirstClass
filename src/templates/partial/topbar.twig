<section class="topbar py-[14px] md:py-[14px] w-full">
	<div class="container flex flex-col justify-center mx-auto md:flex-row md:justify-between lg:justify-between xl:justify-between">
		<div class="hidden md:flex lg:flex xl:flex gap-[10px] lg:gap-[80px]">
			{% for address in global.address %}
			<div class="flex items-start">
				<img src="{{ address.icon.url }}" class="w-[24px] h-auto mr-[12px]">
				<div>
					<p class="text-white font-bold mb-0 text-[16px] leading-none mb-[14px]">{{ address.title }}</p>
					<p class="text-white mb-0 text-[14px] leading-relaxed font-normal">{{ address.address }}</p>
				</div>
			</div>
			{% endfor %}

		</div>
		<div
			class="topbar-logos px-[50px] relative block md:hidden lg:hidden xl:hidden">
			<!-- Arrow container -->
			<div class="w-[85vw] mx-auto flex items-center justify-between absolute left-1/2 -translate-x-1/2 top-[50%] -translate-y-1/2 z-10">

				<div class="text-white cursor-pointer swiper-button-prev left-[-20px!important] after:hidden">
					<img src="/wp-content/uploads/2026/03/Vector-1.png">
				</div>

				<div class="text-white cursor-pointer swiper-button-next left-[20px!important] after:hidden">
					<img src="/wp-content/uploads/2026/03/Vector-2.png">
				</div>

			</div>

			<article class="container mx-auto text-center bg-blue">
				<div class="overflow-hidden top-bar swiper">
					<div class="swiper-wrapper">
					{% for address in global.address %}
						<div class="flex items-center justify-center px-4 swiper-slide">
							<div class="flex items-start">
								<img src="{{ address.icon.url }}" class="w-[24px] h-auto mr-[12px]">
								<div class="text-left">
									<p class="text-white font-bold mb-0 text-[16px] leading-none mb-[14px]">{{ address.title }}</p>
									<p class="text-white mb-0 text-[14px] leading-relaxed font-normal">{{ address.address }}</p>
								</div>
							</div>
						</div>
					{% endfor %}	
					</div>
				</div>
			</article>
		</div>
		<div class="flex items-center justify-center mt-[12px] md:mt-0 gap-[10px]">
		{% for social in global.social %}
			<a href="{{ social.link.url }}" target="{{ social.link.target }}" class="h-[37px] w-[37px] rounded-full border border-lighblue p-[12px] bg-bluesecondary">
				<img class="h-[13px] w-auto" src='{{ social.icon.url }}'/>
			</a>
		{% endfor %}	
		</div>
	</div>

</section>
